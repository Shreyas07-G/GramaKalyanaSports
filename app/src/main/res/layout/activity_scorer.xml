<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/score_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/secondary"
        android:titleTextColor="@color/white"
        app:subtitleTextColor="@color/accent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/secondary"
        android:paddingVertical="6dp"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/tv_sport"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:text="Cricket" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_period"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="1st Half"
            android:textSize="11sp"
            android:paddingHorizontal="10dp"
            android:backgroundTint="@color/primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_period"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1st Half"
        android:textSize="12sp"
        android:textColor="#BBFFFFFF"
        android:textAlignment="center"
        android:paddingVertical="4dp"
        android:background="#22FFFFFF" />

    <!-- COMPACT SCOREBOARD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="10dp"
        android:paddingHorizontal="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_team1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEAM 1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_team1_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:lineSpacingMultiplier="0.85" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VS"
            android:textSize="14sp"
            android:textColor="#66FFFFFF"
            android:paddingHorizontal="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_team2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEAM 2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_team2_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:lineSpacingMultiplier="0.85" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_no_match"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No active match. Create a match first."
        android:textColor="#99FFFFFF"
        android:textSize="13sp"
        android:textAlignment="center"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- SCORING BUTTONS scrollable area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TEAM 1 SCORING"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layout_team1_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TEAM 2 SCORING"
                android:textSize="11sp"
                android:textColor="#FF8A65"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layout_team2_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="@color/secondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_undo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="42dp"
                android:text="↩ UNDO"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share_scorecard"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="42dp"
                android:text="📤 SHARE"
                android:textSize="12sp"
                android:backgroundTint="#1565C0" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_end_match"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="🏁 END MATCH"
            android:backgroundTint="#E53935"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
